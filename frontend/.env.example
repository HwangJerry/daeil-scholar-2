# Base URL for canonical links, OG URLs, and absolute asset paths.
# Set to the production domain in prod, or http://localhost:8000 for local dev behind nginx.
VITE_SITE_BASE_URL=https://daeilfoundation.or.kr

# Google Search Console HTML-tag verification code.
# Get it at https://search.google.com/search-console (Add property → HTML tag → copy the content attribute).
# Leave empty until the site is registered; empty value renders a harmless empty meta tag.
VITE_GOOGLE_SITE_VERIFICATION=

# Naver Search Advisor HTML-tag verification code.
# Get it at https://searchadvisor.naver.com (사이트 등록 → HTML 태그 → copy the content).
VITE_NAVER_SITE_VERIFICATION=

# Temporary "Work in Progress" gate code for the user SPA.
# When non-empty, all visitors see a landing page until they enter this code (per-tab sessionStorage).
# Leave EMPTY in dev/preview to disable the gate entirely.
# Remove this var (and src/components/common/WipGate.tsx) once the rewrite is fully live.
VITE_WIP_ADMIN_CODE=
