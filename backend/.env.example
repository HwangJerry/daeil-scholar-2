# Server
SERVER_PORT=8080
ALLOWED_ORIGIN=http://localhost:8000
SHUTDOWN_TIMEOUT=10s

# Database (MariaDB 10.1)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=alumni
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=3m

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# JWT
JWT_SECRET=change-me-in-production
JWT_MAX_AGE=24h

# File Upload
UPLOAD_BASE_PATH=/var/www/uploads
UPLOAD_LEGACY_PATH=/var/www/legacy/files
UPLOAD_MAX_FILE_SIZE_MB=10

# Go Runtime (production)
# GOMEMLIMIT=80MiB
# GOMAXPROCS=1
